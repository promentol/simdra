{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "simdra-pdfjs-serverless",
  "main": "index.js",
  "compatibility_date": "2025-05-05",
  // simdra's bundle has a dynamic `import("node:worker_threads")` inside
  // zigar's runtime (used only when Web Workers are unavailable). Workers
  // will never enter that branch, but the static analyzer flags it without
  // this flag. Same as examples/cloudflare-workers/wrangler.jsonc.
  "compatibility_flags": ["nodejs_compat"]
}
